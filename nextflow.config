// Nextflow configuration for scMINA workflows
// This file configures Nextflow to use the scmina conda environment

process {
    // Use conda environment for all processes
    conda = 'environment.yml'
    
    // Resource allocation
    cpus = 4
    memory = '8.GB'
    time = '1.h'
    
    // Error handling
    errorStrategy = 'retry'
    maxRetries = 3
    
    // Resource limits
    withLabel: 'high_memory' {
        memory = '32.GB'
        cpus = 8
    }
    
    withLabel: 'gpu' {
        clusterOptions = '-p gpu --gres=gpu:1'
        memory = '16.GB'
        cpus = 4
    }
}

// Environment variables
env {
    // Set Python path to include scmina
    PYTHONPATH = "${projectDir}/scmina:${env.PYTHONPATH}"
    
    // R library path
    R_LIBS_USER = "${projectDir}/.conda/envs/scmina/lib/R/library"
}

// Executor configuration
executor {
    name = 'slurm'  // or 'pbs', 'sge', 'local' depending on your cluster
    queueSize = 100
}

// Workflow options
workflow {
    // Enable conda environment caching
    conda.cacheDir = "${projectDir}/.conda"
    
    // Enable resume functionality
    resume = true
    
    // Error reporting
    errorReport = true
    email = 'hrhu@ucdavis.edu'
}

// Docker configuration (alternative to conda)
docker {
    enabled = false
    // If you prefer Docker, uncomment and configure:
    // runOptions = '-u $(id -u):$(id -g)'
    // temp = 'auto'
}

// Singularity configuration (alternative to conda)
singularity {
    enabled = false
    // If you prefer Singularity, uncomment and configure:
    // autoMounts = true
    // cacheDir = "${projectDir}/.singularity"
}
