// Nextflow configuration for scMINA workflows
// This file configures Nextflow to use the scmina conda environment

process {
    // Default: use conda environment for all processes
    conda = 'environment.yml'
    // Save final outputs under params.output_dir (default: projectDir/results)
    publishDir = { params.output_dir ?: "${projectDir}/results" }
    publishDirMode = 'copy'
    publishDirOverWrite = true
    
    // Resource allocation
    cpus = 8
    memory = '32.GB'
    time = '1.h'
    
    // Error handling
    errorStrategy = 'retry'
    maxRetries = 3
    
    // Resource limits
    withLabel: 'high_memory' {
        memory = '128.GB'
        cpus = 8
    }
    
    withLabel: 'gpu' {
        clusterOptions = '-p gpu --gres=gpu:1'
        memory = '64.GB'
        cpus = 8
    }
}

// Environment variables
// Minimal env block; avoid nested env.env errors
env = [:]

// Executor configuration
executor {
    name = 'slurm'  // overridden by profiles for local testing
    queueSize = 100
}

// Workflow options
workflow {
    // Enable conda environment caching
    conda.cacheDir = "${projectDir}/.conda"
    
    // Enable resume functionality
    resume = true
    
    // Error reporting
    errorReport = true
    email = 'hrhu@ucdavis.edu'
}

// Docker configuration (alternative to conda)
docker {
    enabled = false
    // If you prefer Docker, uncomment and configure:
    // runOptions = '-u $(id -u):$(id -g)'
    // temp = 'auto'
}

// Singularity configuration (alternative to conda)
singularity {
    enabled = false
    // If you prefer Singularity, uncomment and configure:
    // autoMounts = true
    // cacheDir = "${projectDir}/.singularity"
}

// -----------------------------------------------------------------------------
// Profiles
// -----------------------------------------------------------------------------
profiles {
    local_activated {
    process {
        conda = null
        cpus = 2
        memory = '32.GB'
        time = '30.min'

        withName: 'python_processing' { cpus = 2; memory = '32.GB' }
        withName: 'r_visualization'   { cpus = 2; memory = '32.GB' }
        withName: 'generate_report'   { cpus = 1; memory = '32.GB' }
        withName: 'scpair_train'      { cpus = 8; memory = '64.GB' }
        withName: 'scpair_inference'  { cpus = 8; memory = '32.GB' }
        withName: 'scpair_cluster'     { cpus = 8; memory = '64.GB' }
        withName: 'feature_attribution'{ cpus = 8; memory = '64.GB' }
    }
    executor { name = 'local' }
    // Repo-local working directory
    workDir = "${projectDir}/work"
    }
}
